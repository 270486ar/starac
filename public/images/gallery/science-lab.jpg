<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#eff6ff"/>
      <stop offset="100%" stop-color="#dbeafe"/>
    </linearGradient>

    <linearGradient id="table" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#94a3b8"/>
      <stop offset="100%" stop-color="#64748b"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="600" fill="url(#bg)"/>

  <!-- Title -->
  <text x="400" y="70"
        text-anchor="middle"
        font-size="34"
        font-family="Poppins, Arial"
        font-weight="700"
        fill="#1e3a8a">
    Science Laboratory
  </text>

  <text x="400" y="105"
        text-anchor="middle"
        font-size="18"
        font-family="Arial"
        fill="#2563eb">
    Stars Academy
  </text>

  <!-- Table -->
  <rect x="120" y="360" width="560" height="26" rx="5" fill="url(#table)"/>

  <!-- Microscope -->
  <g transform="translate(190 200)">
    <rect x="45" y="120" width="18" height="90" fill="#334155"/>
    <circle cx="54" cy="35" r="22" fill="#0f172a"/>
    <rect x="45" y="55" width="18" height="60" fill="#475569"/>
    <path d="M55 60 Q120 90 95 170" fill="none" stroke="#334155" stroke-width="12"/>
    <ellipse cx="55" cy="215" rx="45" ry="10" fill="#475569"/>
  </g>

  <!-- Flask -->
  <g transform="translate(380 220)">
    <path d="M40 0 L60 0 L60 40 L90 120
             Q95 145 70 150
             L30 150
             Q5 145 10 120
             L40 40 Z"
          fill="#7dd3fc"
          stroke="#0f766e"
          stroke-width="4"/>
    <rect x="40" y="0" width="20" height="22" fill="#e2e8f0"/>
  </g>

  <!-- Test Tube -->
  <g transform="translate(550 200)">
    <rect x="0" y="0" width="30" height="130"
          rx="15"
          fill="#bfdbfe"
          stroke="#1d4ed8"
          stroke-width="4"/>
    <rect x="5" y="70" width="20" height="50"
          fill="#22c55e"/>
  </g>

  <!-- Molecule -->
  <g transform="translate(620 120)">
    <circle cx="0" cy="0" r="10" fill="#2563eb"/>
    <circle cx="45" cy="20" r="10" fill="#3b82f6"/>
    <circle cx="25" cy="55" r="10" fill="#60a5fa"/>
    <line x1="0" y1="0" x2="45" y2="20" stroke="#2563eb" stroke-width="3"/>
    <line x1="45" y1="20" x2="25" y2="55" stroke="#2563eb" stroke-width="3"/>
    <line x1="25" y1="55" x2="0" y2="0" stroke="#2563eb" stroke-width="3"/>
  </g>

  <!-- Floating Science Icons -->
  <text x="120" y="160" font-size="36">🧪</text>
  <text x="180" y="140" font-size="34">⚛️</text>
  <text x="660" y="170" font-size="34">🔬</text>

  <!-- Bottom Label -->
  <text x="400"
        y="540"
        text-anchor="middle"
        font-size="20"
        font-family="Arial"
        fill="#475569">
    Modern Laboratory • Practical Learning • Innovation
  </text>
</svg>
